{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "experimentalServices": {
    "frontend": {
      "root": "apps/frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "apps/backend",
      "routePrefix": "/_/backend",
      "builder": "@vercel/node",
      "runtime": "nodejs18.x",
      "entrypoint": "src/index.ts"
    }
  }
}
